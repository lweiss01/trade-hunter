APP_HOST=127.0.0.1
APP_PORT=8765
ENABLE_SIMULATION=true
ENABLE_KALSHI=false
DISCORD_WEBHOOK_URL=
DISCORD_ALERT_MODE=all
DISCORD_ANALYST_FOLLOWUP=true
DISCORD_ANALYST_MIN_CONFIDENCE=medium
INGEST_API_TOKEN=
POLYALERTHUB_TOKEN=

SPIKE_MIN_VOLUME_DELTA=120
SPIKE_MIN_PRICE_MOVE=0.03
SPIKE_SCORE_THRESHOLD=3.0
SPIKE_BASELINE_POINTS=24
SPIKE_COOLDOWN_SECONDS=300

RETENTION_DAYS=7

# Tracked tickers are now managed in the app (Markets page) and stored in
# data/watchlist.json, NOT here. This line is only read ONCE, to seed the
# watchlist on first run — after that, edit your tickers in the app.
KALSHI_MARKETS=KXBTC-26DEC31-B110000,KELECT-28NOV04-TX-D
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# AI analyst — ordered failover across providers/keys
ANTHROPIC_API_KEY=
