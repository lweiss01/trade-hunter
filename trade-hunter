#!/usr/bin/env bash

# Determine port (default 8765, check .env if present)
PORT=8765
if [ -f .env ]; then
    ENV_PORT=$(grep "^PORT=" .env | cut -d '=' -f2)
    if [ ! -z "$ENV_PORT" ]; then
        PORT=$ENV_PORT
    fi
fi

# Try to gracefully shut down any existing local instance
echo "[launcher] checking for existing instance on port $PORT..."
if curl -s -X POST http://127.0.0.1:$PORT/api/admin/shutdown > /dev/null 2>&1; then
    echo "[launcher] sent shutdown signal to existing instance. waiting for it to exit..."
    sleep 2
fi

# Start the new instance
echo "[launcher] starting Trade Hunter..."
python3 -m app "$@"
